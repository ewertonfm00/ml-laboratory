{
  "name": "[ML-OPERACIONAL] Análise de Processo",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 60
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.id AS sessao_id, s.area, s.dados_coletados, s.updated_at FROM ml_captura.sessoes_conversa s WHERE s.area = 'operacional' AND s.updated_at < NOW() - INTERVAL '30 minutes' AND NOT EXISTS ( SELECT 1 FROM ml_operacional.processos p WHERE p.sessao_id = s.id ) ORDER BY s.updated_at ASC LIMIT 20",
        "options": {}
      },
      "id": "buscar-dados",
      "name": "Buscar Sessões Pendentes",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [460, 300],
      "credentials": {
        "postgres": {
          "name": "ML Postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-data",
              "leftValue": "={{ $json.sessao_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "tem-dados",
      "name": "Tem Dados?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst dadosColetados = item.dados_coletados || {};\nconst textoAnalise = typeof dadosColetados === 'string' ? dadosColetados : JSON.stringify(dadosColetados);\n\nconst prompt = `Você é um especialista em análise de processos operacionais. Analise os dados abaixo e retorne um JSON estruturado.\n\nDados da sessão operacional:\n${textoAnalise}\n\nRetorne APENAS um JSON válido com a seguinte estrutura:\n{\n  \"processo_nome\": \"nome descritivo do processo identificado\",\n  \"etapas\": [\"etapa 1\", \"etapa 2\", \"etapa 3\"],\n  \"gargalos\": [\"gargalo 1\", \"gargalo 2\"],\n  \"inconsistencias\": [\"inconsistencia 1\"],\n  \"criticidade\": \"baixa|media|alta|critica\"\n}\n\nNão inclua markdown, apenas o JSON puro.`;\n\nreturn [{\n  json: {\n    ...item,\n    prompt\n  }\n}];"
      },
      "id": "preparar-prompt",
      "name": "Preparar Prompt Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ML_ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={{ JSON.stringify({model: $env.ML_CLAUDE_CLASSIFIER_MODEL || 'claude-haiku-4-5-20251001', max_tokens: 1024, messages: [{role: 'user', content: $json.prompt}]}) }}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "claude-analise",
      "name": "Claude Análise de Processo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.content?.[0]?.text || '{}';\nlet parsed;\ntry { parsed = JSON.parse(content); } catch(e) { parsed = {erro: 'parse_failed', raw: content}; }\nreturn [{json: {...$input.first().json, resultado: parsed}}];"
      },
      "id": "parsear-resposta",
      "name": "Parsear Resposta Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO ml_operacional.processos (area, processo_nome, etapas, gargalos, inconsistencias, criticidade, sessao_id, created_at, updated_at) VALUES ( 'operacional', '{{ $json.resultado.processo_nome || \"Processo sem nome\" }}', '{{ JSON.stringify($json.resultado.etapas || []) }}'::jsonb, '{{ JSON.stringify($json.resultado.gargalos || []) }}'::jsonb, '{{ JSON.stringify($json.resultado.inconsistencias || []) }}'::jsonb, '{{ [\"baixa\",\"media\",\"alta\",\"critica\"].includes($json.resultado.criticidade) ? $json.resultado.criticidade : \"media\" }}', '{{ $json.sessao_id }}', NOW(), NOW() ) ON CONFLICT DO NOTHING",
        "options": {}
      },
      "id": "salvar-resultado",
      "name": "Salvar Processo",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1560, 300],
      "credentials": {
        "postgres": {
          "name": "ML Postgres"
        }
      }
    }
  ],
  "connections": {
    "schedule-trigger": {
      "main": [
        [
          {
            "node": "buscar-dados",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "buscar-dados": {
      "main": [
        [
          {
            "node": "tem-dados",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "tem-dados": {
      "main": [
        [
          {
            "node": "preparar-prompt",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "preparar-prompt": {
      "main": [
        [
          {
            "node": "claude-analise",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "claude-analise": {
      "main": [
        [
          {
            "node": "parsear-resposta",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "parsear-resposta": {
      "main": [
        [
          {
            "node": "salvar-resultado",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
