  "actionList": [
    {
      "id": "act_get_projetos",
      "name": "getProjects",
      "pageId": "page_projetos",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT p.id, p.nome, p.slug, p.descricao, p.ativo, COUNT(n.id) AS total_numeros, p.created_at FROM _plataforma.projetos p LEFT JOIN _plataforma.numeros_projeto n ON n.projeto_id = p.id GROUP BY p.id ORDER BY p.nome;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": true,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_numeros",
      "name": "getNumerosByProject",
      "pageId": "page_projetos",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT n.id, n.numero_whatsapp, n.nome_identificador, n.setor, n.status, n.total_mensagens, n.ultima_mensagem_em, n.multi_agente, n.ferramenta_multiagente FROM _plataforma.numeros_projeto n WHERE n.projeto_id = '{{tblProjects.selectedRow.id}}' ORDER BY n.nome_identificador;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": false,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_skills",
      "name": "getSkillCategorias",
      "pageId": "page_skills",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT c.id, c.nome, c.tipo, c.subcategoria, c.descricao, c.ativa, COUNT(s.id) AS total_skills FROM _plataforma.skill_categorias c LEFT JOIN _plataforma.skills s ON s.categoria_id = c.id GROUP BY c.id, c.nome, c.tipo, c.subcategoria, c.descricao, c.ativa ORDER BY c.tipo, c.nome;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": true,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_skills_detail",
      "name": "getSkillsByCategoria",
      "pageId": "page_skills",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT s.id, s.nome, s.descricao, s.nivel_minimo, s.nivel_maximo, s.ativa FROM _plataforma.skills s WHERE s.categoria_id = '{{tblCategorias.selectedRow.id}}' ORDER BY s.nome;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": false,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_agente_perfis",
      "name": "getAgentePerfis",
      "pageId": "page_agente",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT ap.id, ap.nome_agente, ap.tipo_disc, ap.perfil_resumo, ap.pontos_fortes, ap.pontos_desenvolvimento, ap.estilo_comunicacao, ap.motivadores, ap.updated_at FROM _plataforma.agente_perfis ap ORDER BY ap.updated_at DESC;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": true,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_performance",
      "name": "getAgentePerformance",
      "pageId": "page_agente",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT perf.id, perf.agente_id, perf.metrica, perf.valor, perf.periodo, perf.updated_at FROM _plataforma.agente_performance perf ORDER BY perf.periodo DESC LIMIT 50;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": true,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_get_fila",
      "name": "getFilaValidacao",
      "pageId": "page_fila",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "SELECT fv.id, fv.produto_mencionado, fv.resposta_detectada, fv.status_validacao, fv.confianca_automatica, fv.validado_por, fv.criado_em, fv.atualizado_em FROM _validacao.fila_validacao fv ORDER BY CASE fv.status_validacao WHEN 'pendente_humano' THEN 1 WHEN 'pendente_auto' THEN 2 ELSE 3 END, fv.criado_em ASC;",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": true,
      "isValid": true,
      "confirmBeforeExecute": false
    },
    {
      "id": "act_aprovar_validacao",
      "name": "aprovarValidacao",
      "pageId": "page_fila",
      "pluginType": "DB",
      "datasource": { "id": "ds_ml_portal", "name": "ML Portal DB" },
      "actionConfiguration": {
        "body": "UPDATE _validacao.fila_validacao SET status_validacao = 'aprovado', atualizado_em = NOW() WHERE id = '{{tblFila.selectedRow.id}}'; SELECT * FROM _validacao.fila_validacao WHERE id = '{{tblFila.selectedRow.id}}';",
        "timeoutInMillisecond": 10000,
        "paginationType": "NONE",
        "encodeParamsToggle": true
      },
      "executeOnLoad": false,
      "isValid": true,
      "confirmBeforeExecute": true
    }
  ],
