# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials

# =============================================================================
# ML Laboratory — Variáveis de Ambiente (Projeto Machine Learning)
# ISOLAMENTO: Prefixo ML_ em tudo — não conflita com outros projetos
# =============================================================================

# POSTGRES — Railway (conexão pública via mainline proxy)
ML_PG_URL=postgresql://postgres:<PASSWORD>@mainline.proxy.rlwy.net:13932/railway
ML_PG_HOST=mainline.proxy.rlwy.net
ML_PG_PORT=13932
ML_PG_DATABASE=railway
ML_PG_USER=postgres
ML_PG_PASSWORD=

# POSTGRES — URL interna Railway (mais rápida, use nos serviços deployados)
ML_PG_INTERNAL_URL=postgresql://postgres:<PASSWORD>@postgres.railway.internal:5432/railway

# POSTGRES — schemas ml_* isolados (legado — preferir ML_PG_URL)
ML_DATABASE_URL=postgresql://ml_app:SENHA_AQUI@host:5432/nome_do_banco
ML_DATABASE_POOL_MIN=2
ML_DATABASE_POOL_MAX=10

# REDIS — prefixo ml: em todas as chaves
ML_REDIS_URL=redis://default:<PASSWORD>@redis.railway.internal:6379
ML_REDIS_HOST=redis.railway.internal
ML_REDIS_PORT=6379
ML_REDIS_PASSWORD=
ML_REDIS_PREFIX=ml:
ML_REDIS_KEY_PREFIX=ml:
ML_REDIS_TTL_SESSAO=86400
ML_REDIS_TTL_ANALISE=3600

# EVOLUTION API — instância ml-omega-laser (isolada)
ML_EVOLUTION_API_URL=https://sua-evolution-api.com
ML_EVOLUTION_API_KEY=SUA_CHAVE_AQUI
ML_EVOLUTION_INSTANCE=ml-omega-laser
ML_EVOLUTION_WEBHOOK_SECRET=SEGREDO_WEBHOOK_AQUI

# N8N — workflows [ML-*]
ML_N8N_URL=https://seu-n8n.railway.app
ML_N8N_BASE_URL=https://n8n-production-47d0.up.railway.app
ML_N8N_WEBHOOK_URL=https://n8n-production-47d0.up.railway.app/webhook
ML_N8N_API_KEY=SUA_CHAVE_N8N_AQUI
ML_N8N_WEBHOOK_PATH=/ml/webhook/whatsapp
ML_N8N_USER=
ML_N8N_PASSWORD=
ML_N8N_ENCRYPTION_KEY=

# GROQ — Whisper para transcrição de áudio
ML_GROQ_API_KEY=SUA_CHAVE_GROQ_AQUI
ML_GROQ_WHISPER_MODEL=whisper-large-v3
ML_GROQ_WHISPER_LANGUAGE=pt

# CLAUDE — Haiku para classificação, Sonnet para análise
ML_ANTHROPIC_API_KEY=SUA_CHAVE_ANTHROPIC_AQUI
ML_CLAUDE_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
ML_CLAUDE_ANALYST_MODEL=claude-sonnet-4-6

# APP
ML_NODE_ENV=development
ML_LOG_LEVEL=info
ML_AREA_PADRAO=comercial
ML_SESSAO_TIMEOUT_MINUTOS=30

# PORTAL — Appsmith + Metabase
ML_PORTAL_DB_URL=postgresql://portal_app:SENHA_AQUI@host:5432/nome_do_banco
ML_PORTAL_DB_PASSWORD=SENHA_PORTAL_APP_AQUI

# Metabase — BI / Dashboards
ML_METABASE_BASE_URL=https://analytics.seudominio.com
ML_METABASE_URL=https://analytics.seudominio.com
ML_METABASE_ADMIN_EMAIL=
ML_METABASE_ADMIN_PASSWORD=
ML_METABASE_EMBEDDING_SECRET=SEGREDO_EMBEDDING_32_CHARS

# Appsmith — Portal Low-code
ML_APPSMITH_BASE_URL=https://portal.seudominio.com
ML_APPSMITH_URL=https://portal.seudominio.com
ML_APPSMITH_ADMIN_EMAIL=
ML_APPSMITH_ADMIN_PASSWORD=
ML_APPSMITH_ENCRYPTION_PASSWORD=SENHA_FORTE_32_CHARS
ML_APPSMITH_ENCRYPTION_SALT=SALT_16_CHARS

ML_NOTIFICATION_POLLING_INTERVAL=30
ML_NOTIFICATION_ERRO_THRESHOLD=5
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below
